# ══════════════════════════════════════
# NaticMA — Environment Variables
# انسخ هذا الملف إلى .env وعبّئ البيانات
# ══════════════════════════════════════

PORT=5000
NODE_ENV=production

# MongoDB Atlas ← https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/naticma

# JWT Secret ← اكتب أي كلمة سر طويلة عشوائية
JWT_SECRET=naticma_super_secret_change_this_2024

# Namecheap API ← namecheap.com > Profile > Tools > API Access
NAMECHEAP_API_USER=your_namecheap_username
NAMECHEAP_API_KEY=your_namecheap_api_key
NAMECHEAP_CLIENT_IP=your_railway_server_ip
NAMECHEAP_SANDBOX=false

# Lemon Squeezy ← app.lemonsqueezy.com
LS_API_KEY=your_lemon_squeezy_api_key
LS_STORE_ID=12345
LS_VARIANT_ID=67890
LS_WEBHOOK_SECRET=your_webhook_signing_secret

# Frontend URL
FRONTEND_URL=https://naticma.vercel.app
